# ============================================
# ReplyMind AI - Frontend Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values

# ---- API ----
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- NextAuth ----
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# ---- Facebook OAuth ----
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret
NEXT_PUBLIC_FACEBOOK_CLIENT_ID=your-facebook-app-id

# ---- Database (for NextAuth adapter) ----
DATABASE_URL="postgresql://user:password@localhost:5432/replymind_ai?schema=public"

# ---- Stripe ----
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key